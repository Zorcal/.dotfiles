#!/usr/bin/env bash
set -euo pipefail

# Branches to keep
KEEP=("master" "main")

TARGET_MODE=false

if [[ "${1:-}" == "--target" ]]; then
  TARGET_MODE=true
fi

# Get current working directory (resolved path)
current_dir="$(pwd -P)"

# Build worktree list: "path|branch"
mapfile -t worktrees < <(
  git worktree list --porcelain | awk '
    /^worktree / { wt=$2 }
    /^branch / {
      br=$2
      sub("refs/heads/","",br)
      print wt "|" br
    }
  '
)

# Function: check if branch is in KEEP
is_kept() {
  local b="$1"
  for k in "${KEEP[@]}"; do
    [[ "$b" == "$k" ]] && return 0
  done
  return 1
}

# Filter candidates
candidates=()
for entry in "${worktrees[@]}"; do
  wt="${entry%%|*}"
  br="${entry##*|}"

  # Skip current directory
  if [[ "$wt" == "$current_dir" ]]; then
    continue
  fi

  # Skip whitelist
  if is_kept "$br"; then
    continue
  fi

  candidates+=("$wt|$br")
done

if [[ ${#candidates[@]} -eq 0 ]]; then
  echo "No worktrees to clean."
  exit 0
fi

# TARGET MODE (fzf selection)
if $TARGET_MODE; then
  if ! command -v fzf >/dev/null 2>&1; then
    echo "fzf is required for --target mode."
    exit 1
  fi

  selected=$(
    printf "%s\n" "${candidates[@]}" |
    sed 's/|/  →  /' |
    fzf --prompt="Select worktree to clean: "
  )

  [[ -z "$selected" ]] && exit 0

  # Convert back to original format
  selected="${selected/  →  /|}"
  candidates=("$selected")
fi

# Cleanup
for entry in "${candidates[@]}"; do
  wt="${entry%%|*}"
  br="${entry##*|}"

  echo "Removing worktree: $wt (branch: $br)"
  git worktree remove --force "$wt"

  if git show-ref --verify --quiet "refs/heads/$br"; then
    echo "Deleting branch: $br"
    git branch -D "$br"
  fi
done

echo "Cleanup complete."
